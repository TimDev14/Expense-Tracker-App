# Used by Flask to sign application data. Generate a long random value for each environment.
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret

# SQLite is the local default. Use an absolute PostgreSQL URL when deploying at scale.
DATABASE_URL=sqlite:///expense_tracker.db
FRONTEND_ORIGIN=http://localhost:5173
